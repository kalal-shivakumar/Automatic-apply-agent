# OpenAI API Key for answering job questionnaires
OPENAI_API_KEY=your_openai_api_key_here

# Job search preferences
JOB_KEYWORDS=Python Developer
JOB_LOCATION=Bangalore
EXPERIENCE_YEARS=3

# Your profile summary (used by AI to answer questions)
YOUR_NAME=Your Name
YOUR_EMAIL=your_email@example.com
YOUR_PHONE=9999999999
YOUR_EXPERIENCE=3 years of experience in Python, Django, Flask, REST APIs
YOUR_SKILLS=Python, Django, Flask, REST APIs, SQL, Git, Docker
YOUR_EDUCATION=B.Tech in Computer Science
YOUR_CURRENT_COMPANY=Current Company Name
YOUR_CURRENT_ROLE=Software Developer
YOUR_NOTICE_PERIOD=30 days
YOUR_EXPECTED_CTC=12 LPA
YOUR_CURRENT_CTC=9 LPA

# Max number of jobs to apply
MAX_APPLICATIONS=20
